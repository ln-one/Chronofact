CHAIN_RPC_URL=http://127.0.0.1:7545

# Optional. Leave empty for Ganache unlocked-account mode.
# If your RPC does not expose unlocked accounts, set a local-only private key.
CHAIN_PRIVATE_KEY=

# Output created by scripts/deploy_contract.js.
CHRONOFACT_REGISTRY_DEPLOYMENT=deployments/ganache/ChronofactRegistry.json

# Optional: point chronofact-api at the course Solidity contract instead of the
# mock witness adapter. Use the deployed address from deployments/ganache.
CHRONOFACT_COURSE_EVM_URL=http://127.0.0.1:7545
CHRONOFACT_REGISTRY_ADDRESS=
